      :root[data-theme-pref='light'] .theme-toggle .ic-sun { display: block; }
      :root[data-theme-pref='auto'] .theme-toggle .ic-auto,
      :root:not([data-theme-pref]) .theme-toggle .ic-auto { display: block; }

      /* hero */
      .hero {
        display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 56px;
        align-items: center; padding: 72px 0 88px;
      }
