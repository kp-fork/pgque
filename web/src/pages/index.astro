      .anchor-link {
        position: absolute; left: -1.15em; top: 0;
        font-family: var(--mono); font-weight: 500; color: var(--muted);
        opacity: 0; transform: translateX(3px);
        transition: opacity 0.16s ease, transform 0.16s ease, color 0.16s ease;
        text-decoration: none; line-height: inherit;
      }
      .anchor-link:hover { color: var(--accent); text-decoration: none; }
      .anchored:hover .anchor-link,
      .anchor-link:focus-visible { opacity: 0.75; transform: translateX(0); }
      @media (max-width: 720px) { .anchor-link { display: none; } }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        transition: background 0.3s ease, color 0.3s ease;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      code { font-family: var(--mono); font-size: 0.92em; }
      /* display headings = condensed frontier-tech face */
      h1, h2, h3, .section-title {
        font-family: var(--display); letter-spacing: 0.01em; text-transform: none;
      }
      /* mono-forward chrome: labels, nav, buttons, tables, terminal bits */
      .eyebrow, .nav-links, .gh-star, .btn,
      .feature-n, .client-name, table.cmp, .legend, .footer-copy,
      .console-title, .console-meta {
        font-family: var(--mono);
      }
      h1, h2, h3 { line-height: 1.1; letter-spacing: 0; font-weight: 700; }
      main { max-width: 1140px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
      .sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }

      /* atmosphere: a static dusk-horizon gradient + faint scanlines + a thin grid.
         No motion lives here — the only animation on the page is the benchmark GIF. */
      .bg-field {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        background:
          radial-gradient(120% 80% at 50% -10%, var(--glow), transparent 55%),
          radial-gradient(90% 60% at 12% 4%, var(--glow-steel), transparent 50%),
          linear-gradient(180deg, transparent 55%, var(--glow) 140%),
          repeating-linear-gradient(0deg, var(--scan) 0 1px, transparent 1px 3px),
          repeating-linear-gradient(90deg, var(--grid) 0 1px, transparent 1px 40px);
        opacity: 0.85;
        mask-image: linear-gradient(180deg, #000 0%, #000 65%, transparent 100%);
      }
      /* Light mode reads busier behind cards — drop the texture ~15%. */
      :root[data-theme='light'] .bg-field { opacity: 0.72; }

      /* reveal-on-scroll */
      .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s cubic-bezier(.22,.61,.36,1); }
      .reveal.is-in { opacity: 1; transform: none; }

      /* nav */
      .nav {
        position: sticky; top: 0; z-index: 50;
        border-bottom: 1px solid transparent;
        transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
      }
      /* Frosted backdrop + hairline appear once the page is scrolled. */
      .nav.is-stuck {
        background: color-mix(in srgb, var(--bg) 78%, transparent);
        backdrop-filter: saturate(140%) blur(10px);
        -webkit-backdrop-filter: saturate(140%) blur(10px);
        border-bottom-color: var(--border-soft);
      }
      @supports not (backdrop-filter: blur(1px)) {
        .nav.is-stuck { background: color-mix(in srgb, var(--bg) 94%, transparent); }
      }
      .nav-inner {
        max-width: 1140px; margin: 0 auto; padding: 18px 24px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .brand { display: flex; align-items: center; gap: 11px; color: var(--text); }
      .brand:hover { text-decoration: none; }
      .brand-mark { display: inline-flex; flex-direction: column; gap: 3px; width: 22px; }
      .brand-mark span { height: 4px; border-radius: 2px; display: block; transition: transform 0.25s ease; }
      .brand-mark span:nth-child(1) { background: var(--blue-light); }
      .brand-mark span:nth-child(2) { background: var(--blue); }
      .brand-mark span:nth-child(3) { background: var(--amber); }
      .brand:hover .brand-mark span:nth-child(1) { transform: translateX(3px); }
      .brand:hover .brand-mark span:nth-child(3) { transform: translateX(-3px); }
      .brand-word { font-family: var(--mono); font-weight: 700; font-size: 1.3rem; letter-spacing: -0.03em; }
      .brand.small .brand-word { font-size: 1.1rem; }
      .nav-links { display: flex; gap: 20px; align-items: center; }
      .nav-links a:not(.gh-star) { color: var(--muted); font-size: 0.95rem; }
      .nav-links a:not(.gh-star):hover { color: var(--text); text-decoration: none; }

      /* GitHub star widget */
      .gh-star {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 6px 12px; border: 1px solid var(--border); border-radius: 8px;
        background: var(--panel); color: var(--text) !important; font-size: 0.86rem; font-weight: 600;
        transition: border-color 0.18s ease, transform 0.1s ease, background 0.18s ease;
      }
      .gh-star:hover { text-decoration: none; border-color: var(--amber); transform: translateY(-1px); }
      .gh-star svg { color: var(--amber); }
      .gh-count {
        font-variant-numeric: tabular-nums; color: var(--text-2);
        padding-left: 8px; margin-left: 2px; border-left: 1px solid var(--border);
      }
      .gh-count:empty { display: none; }

      /* theme toggle */
      .theme-toggle {
        display: inline-flex; align-items: center; justify-content: center;
        width: 34px; height: 34px; border-radius: 8px; cursor: pointer;
        border: 1px solid var(--border); background: var(--panel); color: var(--text);
        transition: border-color 0.18s ease, color 0.18s ease, transform 0.1s ease;
      }
      .theme-toggle:hover { border-color: var(--accent); transform: translateY(-1px); }
      /* Icon reflects the chosen preference (auto/light/dark), not the resolved theme. */
      .theme-toggle .ic-moon,
      .theme-toggle .ic-sun,
      .theme-toggle .ic-auto { display: none; }
      :root[data-theme-pref='dark'] .theme-toggle .ic-moon { display: block; }
      :root[data-theme-pref='light'] .theme-toggle .ic-sun { display: block; }
      :root[data-theme-pref='auto'] .theme-toggle .ic-auto,
      :root:not([data-theme-pref]) .theme-toggle .ic-auto { display: block; }

      /* hero */
      /* Two-column hero: copy on the left, benchmark console figure on the
         right (vertically aligned with the copy). The visual column is the
         wider track (~52%) so the chart is as large as fits beside the text. */
      .hero {
        display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 48px;
        align-items: center; padding: 72px 0 88px;
      }
      .hero-copy { min-width: 0; }
      .eyebrow {
        display: inline-flex; align-items: center; gap: 8px;
        text-transform: uppercase; letter-spacing: 0.14em; font-size: 0.74rem;
        color: var(--amber); margin: 0 0 18px; font-weight: 700;
      }
      .eyebrow-dot {
        width: 7px; height: 7px; border-radius: 50%; background: var(--amber);
      }
      .hero h1 { font-size: clamp(2.2rem, 4.6vw, 3.4rem); margin: 0 0 10px; font-weight: 800; }
      .subhead {
        font-size: clamp(1.5rem, 3vw, 2.3rem); line-height: 1.12; font-weight: 600;
        font-family: var(--display); letter-spacing: 0; margin: 0 0 26px;
      }
      .accent { color: var(--accent); }
      .lede { font-size: 1.1rem; color: var(--text-2); margin: 0 0 32px; max-width: 58ch; }
      .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }
      .cta-row.center { justify-content: center; }
      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-height: 46px; padding: 0 24px; border-radius: 8px;
        font-weight: 600; font-size: 0.9rem; letter-spacing: 0.02em; border: 1.5px solid transparent;
        text-transform: uppercase;
        transition: transform 0.1s ease, background 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }
      .btn:hover { text-decoration: none; transform: translateY(-2px); }
      .btn-primary { background: var(--blue); color: #fff; box-shadow: 0 8px 24px -10px var(--glow-steel); }
      .btn-primary:hover { background: #3d76a3; box-shadow: 0 12px 30px -10px var(--glow-steel); }
      .btn-ghost { border-color: var(--accent); color: var(--text); background: var(--panel); }
      .btn-ghost:hover { background: var(--panel-2); border-color: var(--accent); }
      .install {
        margin-top: 28px; padding: 12px 16px; background: var(--panel);
        border: 1px solid var(--border); border-radius: 10px; display: inline-flex;
        gap: 10px; align-items: baseline; flex-wrap: wrap; font-family: var(--mono);
      }
      .install-prompt { color: var(--amber); font-weight: 700; }
      .install > code { color: var(--accent); font-weight: 600; }
      .install-note { color: var(--muted); font-size: 0.9rem; }

      /* Benchmark figure beside the hero copy: fills its column, never past
         the chart's native 900px, never overflowing (image width:100%). */
      .hero-visual { margin: 0; min-width: 0; max-width: 900px; }
      .hero-visual figcaption { color: var(--muted); font-size: 0.85rem; margin-top: 16px; line-height: 1.55; }

      /* Restrained console frame around the benchmark readout: a single title
         bar with a hairline divider, precise radii, aligned padding. */
      .console {
        border: 1px solid var(--border); border-radius: 14px; overflow: hidden;
        background: var(--panel);
        box-shadow: 0 24px 60px -32px var(--glow-steel), 0 1px 0 var(--border-soft) inset;
      }
      .console-bar {
        display: flex; align-items: center; gap: 12px; height: 40px; padding: 0 16px;
        /* Full --border 1px divider (not a faint hairline) against the plot. */
        border-bottom: 1px solid var(--border);
        /* Faint fill, a step off the plot surface (--panel). */
        background: color-mix(in srgb, var(--panel-2) 60%, var(--panel));
      }
      .console-title {
        font-size: 0.74rem; letter-spacing: 0.02em; color: var(--text-2); font-weight: 500;
      }
      .console-title code { color: var(--text); font-weight: 600; }
      /* Clean letterboxing: the GIF has a white background, so present it on a
         white mat in both themes with a hairline, evenly inset. */
      .console-body { padding: 16px; background: var(--panel); }
      .console-body img {
        width: 100%; height: auto; display: block; border-radius: 6px;
        background: #fff; border: 1px solid var(--border-soft);
      }

      /* bands */
      .band { position: relative; background: var(--bg-soft); border-top: 1px solid var(--border-soft); border-bottom: 1px solid var(--border-soft); }
      .band-inner { max-width: 1140px; margin: 0 auto; padding: var(--section-y) 24px; position: relative; z-index: 1; }
      .split { display: grid; grid-template-columns: 1fr 1fr; gap: 52px; align-items: center; }
      .split-copy h2 { font-size: clamp(1.7rem, 3vw, 2.1rem); margin: 0 0 20px; max-width: 14ch; text-wrap: balance; }
      .split-copy h2 code { color: inherit; font-size: 0.88em; opacity: 0.92; }
      .split-copy p { color: var(--text-2); margin: 0 0 14px; }
      .split-copy strong { color: var(--text); }
      .split-copy .muted { color: var(--muted); font-size: 0.95rem; }
      .split-code :global(.expressive-code) { font-size: 0.86rem; }
      /* Grid items must be allowed to shrink below content width so the wide
         code block never forces page-level horizontal scroll on narrow views. */
      .split-copy, .split-code { min-width: 0; }
      .split-code :global(.expressive-code) { max-width: 100%; }
      .split-code :global(.expressive-code pre),
      .split-code :global(.expressive-code .code),
      .split-code :global(.frame) { overflow-x: auto; max-width: 100%; }

      .section-title {
        font-size: clamp(1.7rem, 3vw, 2.1rem); text-align: center; margin: 0 0 14px;
      }
      .section-sub { text-align: center; color: var(--muted); max-width: 46em; margin: 0 auto 40px; }

      /* features */
      .features { padding: var(--section-y) 0; }
      .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
      .feature-card {
        position: relative; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 28px 26px; overflow: hidden;
        transition: border-color 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
      }
      .feature-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, var(--blue-light), var(--blue), var(--amber));
        transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease;
      }
      .feature-card:hover { border-color: var(--border); transform: translateY(-3px); box-shadow: 0 18px 40px -24px var(--glow); }
      .feature-card:hover::before { transform: scaleX(1); }
      .feature-n {
        font-family: var(--mono); font-size: 0.78rem; font-weight: 700;
        color: var(--accent); letter-spacing: 0.08em; opacity: 0.75;
      }
      .feature-card h3 { margin: 10px 0 10px; font-size: 1.15rem; color: var(--text); letter-spacing: 0; }
      .feature-card p { margin: 0; color: var(--muted); font-size: 0.95rem; line-height: 1.62; }

      /* comparison */
      .table-wrap {
        overflow-x: auto; border: 1px solid var(--border); border-radius: var(--radius);
        background: var(--panel);
      }
      table.cmp { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
      table.cmp th, table.cmp td { padding: 14px 16px; border-bottom: 1px solid var(--border-soft); text-align: left; }
      table.cmp tbody tr:last-child td { border-bottom: none; }
      table.cmp thead th {
        color: var(--text-2); font-weight: 600; background: var(--panel-2);
        border-bottom: 2px solid var(--border);
      }
      table.cmp td:first-child, table.cmp th:first-child { color: var(--text-2); }
      table.cmp tbody tr:nth-child(even) td { background: color-mix(in srgb, var(--panel-2) 45%, transparent); }
      table.cmp tbody tr:hover td { background: var(--panel-2); }
      table.cmp .mark { text-align: center; font-size: 1.1rem; }
      .mark-yes { color: var(--accent-2); }
      .mark-no { color: var(--muted); opacity: 0.5; }
      .mark-partial { color: var(--amber); }
      /* Emphasise the PgQue column: amber wash + bolder, larger ✓ marks. */
      .col-self { background: color-mix(in srgb, var(--amber) 10%, transparent); }
      td.col-self.mark-yes { color: var(--amber); font-size: 1.25rem; font-weight: 700; }
      table.cmp tbody tr:nth-child(even) td.col-self,
      table.cmp tbody tr:hover td.col-self { background: color-mix(in srgb, var(--amber) 14%, transparent); }
      th.col-self { color: var(--amber); font-weight: 800; border-bottom-color: var(--amber); }

      .legend {
        list-style: none; display: flex; flex-wrap: wrap; justify-content: center; gap: 22px;
        padding: 0; margin: 26px 0 0; font-family: var(--mono); font-size: 1rem;
      }
      .legend li {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 7px 14px; border: 1px solid var(--border); border-radius: 999px;
        background: var(--panel); color: var(--text-2);
      }
      .legend .lg { font-size: 1.05rem; line-height: 1; }
      .legend .lg-yes { color: var(--amber); font-weight: 700; }
      .legend .lg-no { color: var(--muted); }
      .legend .lg-partial { color: var(--amber); }

      /* runs on — platform logo wall */
      .runson { padding: var(--section-y) 0; }
      .runson-groups {
        display: flex; flex-direction: column; gap: 38px;
        max-width: 940px; margin: 0 auto;
      }
      .runson-label {
        display: flex; align-items: center; gap: 9px;
        font-family: var(--mono); font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.16em; text-transform: uppercase;
        color: var(--muted); margin: 0 0 16px;
      }
      .runson-tick {
        width: 7px; height: 7px; flex: none; border-radius: 1px;
        background: var(--amber);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--amber) 18%, transparent);
      }
      .runson-wall {
        display: grid; gap: 12px;
        grid-template-columns: repeat(auto-fill, minmax(182px, 1fr));
      }
      .plat-tile {
        display: flex; align-items: center; gap: 13px; min-width: 0;
        padding: 14px 16px; border-radius: var(--radius);
        background: var(--panel); border: 1px solid var(--border);
        transition: border-color 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
      }
      .plat-tile:hover {
        border-color: var(--accent); transform: translateY(-2px);
        box-shadow: 0 16px 36px -26px var(--glow);
      }
      /* Logos render in their REAL brand colours (no mask/recolour). Each sits
         on a subtle neutral chip so pure-white, pure-dark and dark-navy marks
         stay legible on both themes. */
      .plat-chip {
        flex: none; display: flex; align-items: center; justify-content: center;
        width: 38px; height: 38px; border-radius: 9px;
        background: #fbfaf7; border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.5);
        transition: box-shadow 0.18s ease;
      }
      /* Logos are pre-trimmed to a tight, centred square canvas, so a single
         box size gives even optical weight. Square marks sit at 25px; wide
         wordmarks (Oracle, IBM, Ubicloud) are capped by width so they read at
         the same stroke weight without ballooning the chip vertically. */
      .plat-logo { display: block; width: 25px; height: 25px; object-fit: contain; }
      .plat-logo[data-logo='oracle'] { width: 30px; height: 30px; }
      .plat-logo[data-logo='ibm'] { width: 28px; height: 28px; }
      .plat-logo[data-logo='ubicloud'] { width: 29px; height: 29px; }
      /* Tiger Data's badge is a pale yellow circle with a white tiger cutout —
         it vanishes on the light neutral chip. Give just that tile a dark chip
         so the badge reads clearly in both the light and dark themes. */
      .plat-chip--dark {
        background: #1c2230;
        border-color: color-mix(in srgb, #1c2230 70%, transparent);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
      }
      .plat-tile:hover .plat-chip--dark {
        box-shadow: 0 4px 12px -6px var(--glow), inset 0 0 0 1px rgba(255, 255, 255, 0.08);
      }
      .plat-tile:hover .plat-chip {
        box-shadow: 0 4px 12px -6px var(--glow), inset 0 0 0 1px rgba(255, 255, 255, 0.5);
      }
      .plat-name {
        font-family: var(--mono); font-size: 0.86rem; font-weight: 500;
        color: var(--text-2); letter-spacing: -0.01em;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }
      .runson-notes {
        max-width: 940px; margin: 30px auto 0;
        display: flex; flex-direction: column; gap: 7px;
      }
      .runson-notes p {
        margin: 0; font-family: var(--mono); font-size: 0.78rem;
        line-height: 1.5; color: var(--muted);
      }
      .runson-notes a { color: var(--accent); border-bottom: 1px dotted color-mix(in srgb, var(--accent) 55%, transparent); }
      .runson-notes a:hover { border-bottom-style: solid; }
      @media (max-width: 460px) {
        .runson-wall { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
        .plat-tile { padding: 12px 13px; gap: 11px; }
        .plat-name { font-size: 0.8rem; }
      }

      /* clients */
      .clients { padding: var(--section-y) 0; }
      /* Balanced 3-col grid: 3 live (colour) + 3 planned (grayscale) = two rows. */
      .client-row {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
        max-width: 780px; margin: 0 auto;
      }
      .client-card {
        position: relative; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 22px 24px; display: flex; align-items: center; gap: 16px;
        color: var(--text); transition: border-color 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
      }
      a.client-card:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-3px); box-shadow: 0 18px 40px -24px var(--glow); }
      /* One unified logo system: identical 48x48 tiles, 8px radius, 1px border.
         Every mark normalised to the same optical cap-height, centred on the
         shared tile — full colour for live clients, grayscale for planned. */
      .client-logo {
        flex: none; display: inline-flex; align-items: center; justify-content: center;
        width: 48px; height: 48px; border-radius: 8px;
        border: 1px solid var(--border); background: var(--panel-2);
        color: var(--text-2); transition: border-color 0.18s ease, background 0.18s ease;
      }
      /* Marks fill the 48px tile confidently (less inner padding). SVG glyphs
         at 36px; the Go wordmark PNG runs a touch larger to match optically,
         since its art carries built-in whitespace. */
      .client-logo svg { display: block; height: 36px; width: 36px; }
      .client-logo-img { display: block; width: 40px; height: 40px; object-fit: contain; }
      /* Go: theme-aware official logo (blue on light, white on dark). */
      .client-logo .img-dark { display: none; }
      :root[data-theme='dark'] .client-logo .img-light { display: none; }
      :root[data-theme='dark'] .client-logo .img-dark { display: block; }
      a.client-card:hover .client-logo { border-color: var(--accent); }
      .client-text { display: flex; flex-direction: column; gap: 4px; }
      .client-name { font-weight: 700; font-size: 1.05rem; }
      /* Sublabel one contrast step up from the faint grey, toward body ink. */
      .client-card code { color: color-mix(in srgb, var(--text-2) 55%, var(--text)); }
      .client-arrow { position: absolute; top: 16px; right: 18px; color: var(--accent); opacity: 0; transform: translateX(-4px); transition: opacity 0.2s ease, transform 0.2s ease; }
      a.client-card:hover .client-arrow { opacity: 1; transform: none; }

      /* Planned ("soon") clients: quieter, grayscale, not clickable. */
      .client-card--soon { cursor: default; opacity: 0.62; }
      .client-card--soon .client-logo { color: var(--muted); }
      .client-card--soon .client-logo svg { filter: grayscale(1); opacity: 0.85; }
      .client-card--soon .client-name { color: var(--text-2); font-weight: 600; }
      .client-card--soon code { color: var(--muted); }

      /* External-link indicator: subtle mono ↗ so users know they leave the site. */
      .ext-arrow {
        font-family: var(--mono); font-size: 0.78em; line-height: 1;
        margin-left: 0.28em; color: var(--muted); vertical-align: baseline;
      }

      /* final cta */
      .cta-final { padding: var(--section-y) 0; }
      .cta-final-inner {
        text-align: center; max-width: 760px; margin: 0 auto; padding: 56px 32px;
        border: 1px solid var(--border); border-radius: 20px; background: var(--panel);
        box-shadow: 0 30px 80px -40px var(--glow);
        position: relative; overflow: hidden;
      }
      .cta-final-inner::before {
        content: ''; position: absolute; inset: 0; z-index: 0;
        background: radial-gradient(circle at 50% -20%, var(--glow), transparent 60%);
      }
      .cta-final-inner > * { position: relative; z-index: 1; }
      .cta-final h2 { font-size: clamp(1.8rem, 3.4vw, 2.3rem); margin: 0 0 12px; }
      .cta-final p { color: var(--muted); margin: 0 0 30px; }

      /* footer */
      .footer { border-top: 1px solid var(--border); background: var(--panel); position: relative; z-index: 1; }
      .footer-inner {
        max-width: 1140px; margin: 0 auto; padding: 48px 24px;
        display: flex; justify-content: space-between; align-items: flex-start;
        gap: 48px; flex-wrap: wrap;
      }
      /* Link columns grouped at the right edge so the full width reads balanced. */
      .footer-cols { display: flex; gap: 72px; }
      .footer-brand { display: flex; flex-direction: column; gap: 12px; }
      .footer-copy { color: var(--text-2); font-size: 0.92rem; margin: 0; font-weight: 500; display: inline-flex; align-items: center; flex-wrap: wrap; gap: 4px; }
      .footer-social { display: inline-flex; align-items: center; gap: 6px; margin-left: 6px; }
      .footer-social a {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 6px;
        border: 1px solid var(--border-soft); background: var(--panel);
        color: var(--text-2); transition: color 0.18s ease, border-color 0.18s ease, transform 0.1s ease;
      }
      .footer-social a:hover { color: var(--accent); border-color: var(--accent); transform: translateY(-1px); text-decoration: none; }
      .footer-heritage { margin: 0; font-size: 0.85rem; }
      .footer-heritage a { color: var(--muted); }
      .footer-links { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; min-width: 140px; }
      .footer-links-title {
        font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
        color: var(--muted); margin-bottom: 2px;
      }
      .footer-links a { color: var(--text-2); font-size: 0.92rem; }
      .footer-links a:hover { color: var(--accent); text-decoration: none; }
      .muted { color: var(--muted); }

      @media (max-width: 880px) {
        :root { --section-y: 64px; }
        .hero { grid-template-columns: 1fr; gap: 36px; padding: 40px 0 56px; }
        .split { grid-template-columns: 1fr; gap: 30px; }
        .feature-grid { grid-template-columns: 1fr; }
        .client-row { grid-template-columns: repeat(2, 1fr); max-width: 520px; }
        .nav-links a:nth-child(3) { display: none; }
        .gh-star span:not(.gh-count) { display: none; }
      }
      @media (max-width: 520px) {
        .client-row { grid-template-columns: 1fr; max-width: 420px; }
        .nav-links { gap: 12px; }
        .nav-links a:not(.gh-star):not([href='/docs']) { display: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation: none !important; transition: none !important; }
        .reveal { opacity: 1; transform: none; }
        html { scroll-behavior: auto; }
        .bg-field { animation: none; }
      }
    </style>
  </body>
</html>
