      property="og:description"
      content="PgQ repackaged for managed Postgres. One SQL file to install, pg_cron to tick. Snapshot-based batching, native fan-out, no dead tuples."
    />
    <meta property="og:url" content="https://pgque.dev/" />
    <meta property="og:image" content="https://pgque.dev/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Set theme before paint to avoid a flash; sync with Starlight's key. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('starlight-theme');
        const pref = stored === 'light' || stored === 'dark' ? stored : 'auto';
        const sysDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const root = document.documentElement;
        root.dataset.themePref = pref;
        root.dataset.theme = pref === 'auto' ? (sysDark ? 'dark' : 'light') : pref;
      })();
    </script>
  </head>
  <body>
    <div class="bg-field" aria-hidden="true"></div>

    <header class="nav">
      <div class="nav-inner">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="brand-word">PgQue</span>
      </a>
      <nav class="nav-links">
        <a href="/docs/tutorial">Tutorial</a>
        <a href="/docs">Docs</a>
        <a href="/docs/concepts">Concepts</a>
