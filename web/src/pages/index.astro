    <meta
      name="description"
      content="PgQue is a zero-bloat Postgres queue: PgQ repackaged for managed Postgres. One SQL file to install, pg_cron to tick. Snapshot-based batching, native fan-out, no dead tuples."
    />
    <link rel="canonical" href="https://pgque.dev/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="PgQue — zero-bloat Postgres queue" />
