      a:hover { text-decoration: underline; }
      code { font-family: var(--mono); font-size: 0.92em; }
      /* display headings = condensed frontier-tech face */
      h1, h2, h3, .section-title {
        font-family: var(--display); letter-spacing: 0.01em; text-transform: none;
      }
      /* mono-forward chrome: labels, nav, buttons, tables, terminal bits */
      .eyebrow, .nav-links, .gh-star, .btn,
      .feature-n, .client-name, table.cmp, .legend, .footer-copy,
      .console-title, .console-meta {
        font-family: var(--mono);
      }
      h1, h2, h3 { line-height: 1.1; letter-spacing: 0; font-weight: 700; }
      main { max-width: 1140px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
      .sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }

      /* atmosphere: a static dusk-horizon gradient + faint scanlines + a thin grid.
