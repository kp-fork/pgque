        --panel: #181a1f;
        --panel-2: #1f2228;
        --border: #2c3038;
        --border-soft: #23262d;
        --text: #e9e6df;
        --text-2: #c8c4ba;
        --muted: #989488;
        --accent: var(--amber);
        --accent-2: var(--blue-light);
        --grid: rgba(201, 168, 106, 0.08);
        --glow: rgba(240, 136, 62, 0.18);
        --glow-steel: rgba(51, 103, 145, 0.28);
        --metal: linear-gradient(180deg, #1c1e23, #16181c);
        --scan: rgba(255, 255, 255, 0.022);
        color-scheme: dark;
      }
      /* Light = "desert daylight": warm sand/parchment + steel ink */
      :root[data-theme='light'] {
        --bg: #ece5d6;
        --bg-soft: #e3dac8;
        --panel: #f6f1e6;
        --panel-2: #ece4d3;
        --border: #cabfa6;
        --border-soft: #d8cdb6;
        --text: #2a2620;
        --text-2: #4a443a;
        --muted: #6b6456;
        --accent: #b8632a;
        --accent-2: var(--blue);
        --grid: rgba(80, 64, 40, 0.03);
        --glow: rgba(184, 99, 42, 0.14);
        --glow-steel: rgba(51, 103, 145, 0.14);
        --metal: linear-gradient(180deg, #f7f2e7, #efe7d6);
        --scan: rgba(40, 30, 16, 0.018);
        color-scheme: light;
      }

