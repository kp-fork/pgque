      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; overflow-x: hidden; }
      /* deep-linkable sections: offset the smooth-scroll target so the fixed
         nav never covers a section heading when you land on a #-anchor. */
      main > section[id], footer[id] { scroll-margin-top: 88px; }

      /* understated hover-anchor affordance: a faint mono '#' that fades in to
         the left of a section heading and links to that section's URL. */
