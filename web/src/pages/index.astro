      /* clients */
      .clients { padding: var(--section-y) 0; }
      .client-row {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
        max-width: 760px; margin: 0 auto;
      }
      .client-card {
        position: relative; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 22px 24px; display: flex; align-items: center; gap: 16px;
        color: var(--text); transition: border-color 0.18s ease, transform 0.15s ease, box-shadow 0.18s ease;
      }
      .client-card:hover { border-color: var(--accent); text-decoration: none; transform: translateY(-3px); box-shadow: 0 18px 40px -24px var(--glow); }
      /* One unified logo system: identical 48x48 tiles, 8px radius, 1px border,
         same inner padding. Each glyph is normalised to the same optical
         cap-height and centred on the shared tile (no nested tiles, no bleed). */
      .client-logo {
        flex: none; display: inline-flex; align-items: center; justify-content: center;
        width: 48px; height: 48px; border-radius: 8px;
        border: 1px solid var(--border); background: var(--panel-2);
        color: var(--text-2); transition: border-color 0.18s ease, background 0.18s ease;
      }
      .client-logo svg { display: block; }
      /* One monochrome steel set: every glyph in the same tone via currentColor,
         normalised to the same optical cap-height (TS/Python ~24 box, Go wide
         wordmark scaled to match) so the three read as one designed system. */
      .client-logo.fit-square svg { height: 25px; width: 25px; }
      .client-logo.fit-wide   svg { height: 14px; width: auto; }
      .client-logo { color: var(--accent-2); }
      .client-card:hover .client-logo { border-color: var(--accent); color: var(--accent); }
      .client-text { display: flex; flex-direction: column; gap: 4px; }
      .client-name { font-weight: 700; font-size: 1.05rem; }
      /* Sublabel one contrast step up from the faint grey, toward body ink. */
      .client-card code { color: color-mix(in srgb, var(--text-2) 55%, var(--text)); }
      .client-arrow { position: absolute; top: 16px; right: 18px; color: var(--accent); opacity: 0; transform: translateX(-4px); transition: opacity 0.2s ease, transform 0.2s ease; }
      .client-card:hover .client-arrow { opacity: 1; transform: none; }

      /* final cta */
      .cta-final { padding: var(--section-y) 0; }
      .cta-final-inner {
        text-align: center; max-width: 760px; margin: 0 auto; padding: 56px 32px;
        border: 1px solid var(--border); border-radius: 20px; background: var(--panel);
        box-shadow: 0 30px 80px -40px var(--glow);
        position: relative; overflow: hidden;
      }
      .cta-final-inner::before {
        content: ''; position: absolute; inset: 0; z-index: 0;
        background: radial-gradient(circle at 50% -20%, var(--glow), transparent 60%);
      }
      .cta-final-inner > * { position: relative; z-index: 1; }
      .cta-final h2 { font-size: clamp(1.8rem, 3.4vw, 2.3rem); margin: 0 0 12px; }
      .cta-final p { color: var(--muted); margin: 0 0 30px; }

      /* footer */
      .footer { border-top: 1px solid var(--border); background: var(--panel); position: relative; z-index: 1; }
      .footer-inner {
        max-width: 1140px; margin: 0 auto; padding: 48px 24px;
        display: flex; align-items: flex-start; gap: 72px; flex-wrap: wrap;
      }
      .footer-brand { display: flex; flex-direction: column; gap: 12px; }
      .footer-copy { color: var(--text-2); font-size: 0.92rem; margin: 0; font-weight: 500; display: inline-flex; align-items: center; flex-wrap: wrap; gap: 4px; }
      .footer-social { display: inline-flex; align-items: center; gap: 6px; margin-left: 6px; }
      .footer-social a {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 6px;
        border: 1px solid var(--border-soft); background: var(--panel);
        color: var(--text-2); transition: color 0.18s ease, border-color 0.18s ease, transform 0.1s ease;
      }
      .footer-social a:hover { color: var(--accent); border-color: var(--accent); transform: translateY(-1px); text-decoration: none; }
      .footer-heritage { margin: 0; font-size: 0.85rem; }
      .footer-heritage a { color: var(--muted); }
      .footer-links { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; min-width: 140px; }
      .footer-links-title {
        font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
        color: var(--muted); margin-bottom: 2px;
      }
      .footer-links a { color: var(--text-2); font-size: 0.92rem; }
      .footer-links a:hover { color: var(--accent); text-decoration: none; }
      .muted { color: var(--muted); }

      @media (max-width: 880px) {
        :root { --section-y: 64px; }
        .hero { grid-template-columns: 1fr; gap: 40px; padding: 40px 0 56px; }
        .split { grid-template-columns: 1fr; gap: 30px; }
        .feature-grid { grid-template-columns: 1fr; }
        .client-row { grid-template-columns: 1fr; max-width: 420px; }
        .nav-links a:nth-child(3) { display: none; }
        .gh-star span:not(.gh-count) { display: none; }
      }
      @media (max-width: 520px) {
        .nav-links { gap: 12px; }
        .nav-links a:not(.gh-star):not([href='/docs']) { display: none; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation: none !important; transition: none !important; }
        .reveal { opacity: 1; transform: none; }
        html { scroll-behavior: auto; }
        .bg-field { animation: none; }
      }
    </style>
  </body>
</html>
