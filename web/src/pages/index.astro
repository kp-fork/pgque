    <script is:inline>
      // Theme: 3-state preference (auto -> light -> dark -> auto), synced with
      // Starlight. "auto" means follow the OS; we never persist it (Starlight
      // treats a missing stored value as auto), so the docs stay in sync.
      (() => {
        const root = document.documentElement;
        const mq = window.matchMedia('(prefers-color-scheme: dark)');
        const sysTheme = () => (mq.matches ? 'dark' : 'light');

        const apply = (pref) => {
          root.dataset.themePref = pref;
          root.dataset.theme = pref === 'auto' ? sysTheme() : pref;
          const btn = document.querySelector('.theme-toggle');
          if (btn) {
            btn.setAttribute('aria-label', 'Color theme: ' + pref);
            btn.setAttribute('title', 'Theme: ' + pref + ' (click to cycle)');
          }
        };

        const currentPref = () => {
          const s = localStorage.getItem('starlight-theme');
          return s === 'light' || s === 'dark' ? s : 'auto';
        };

        const btn = document.querySelector('.theme-toggle');
        if (btn) {
          btn.addEventListener('click', () => {
            const next = { auto: 'light', light: 'dark', dark: 'auto' }[currentPref()];
            try {
              if (next === 'auto') localStorage.removeItem('starlight-theme');
              else localStorage.setItem('starlight-theme', next);
            } catch {}
            apply(next);
          });
        }

        // Live-follow the OS preference while in auto.
        mq.addEventListener('change', () => {
          if (currentPref() === 'auto') apply('auto');
        });

        // Stay in sync if the theme changes in another tab (e.g. the docs).
        window.addEventListener('storage', (e) => {
          if (e.key === 'starlight-theme') apply(currentPref());
        });

        // Lightweight GitHub star count, async + cached, fails silently.
        const el = document.querySelector('[data-gh-count]');
        if (el) {
          const KEY = 'pgque-gh-stars';
          const fmt = (n) => (n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : '' + n);
          try {
            const cached = JSON.parse(localStorage.getItem(KEY) || 'null');
            if (cached && Date.now() - cached.t < 3600000) el.textContent = fmt(cached.n);
          } catch {}
          fetch('https://api.github.com/repos/NikolayS/pgque')
            .then((r) => (r.ok ? r.json() : null))
            .then((d) => {
              if (d && typeof d.stargazers_count === 'number') {
                el.textContent = fmt(d.stargazers_count);
                try { localStorage.setItem(KEY, JSON.stringify({ n: d.stargazers_count, t: Date.now() })); } catch {}
              }
            })
            .catch(() => {});
        }

        // Sticky-nav frosted backdrop toggles once the page is scrolled.
        const nav = document.querySelector('.nav');
        if (nav) {
          const onScroll = () => nav.classList.toggle('is-stuck', window.scrollY > 8);
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }

        // Benchmark: always lead with the data-rich poster frame on first paint.
        // Swap to the animated GIF on hover only (same dimensions, no shift); do
        // NOT auto-swap on viewport visibility — the hero is above the fold, so
        // that would replace the poster with the GIF's empty first frame at load.
        const bench = document.querySelector('img.benchmark');
        if (bench && bench.dataset.gif) {
          let animated = false;
          bench.addEventListener('mouseenter', () => {
            if (animated) return;
            animated = true;
            bench.src = bench.dataset.gif;
          });
        }

        // Scroll reveals via IntersectionObserver. Must NEVER leave content hidden.
        const items = document.querySelectorAll('.reveal');
        const showAll = () => items.forEach((n) => n.classList.add('is-in'));
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduce || !('IntersectionObserver' in window)) {
          showAll();
        } else {
          const inView = (n) => {
            const r = n.getBoundingClientRect();
            return r.top < (window.innerHeight || 0) && r.bottom > 0;
          };
          // Anything already on screen at load is shown immediately (no fade-in flash).
          items.forEach((n) => { if (inView(n)) n.classList.add('is-in'); });

          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  e.target.classList.add('is-in');
                  io.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
          );
          items.forEach((n) => { if (!n.classList.contains('is-in')) io.observe(n); });

          // Safety net: never let a .reveal stay invisible permanently. If the
          // observer somehow never fires for an element, force it visible.
          setTimeout(showAll, 4000);
        }
      })();
    </script>

