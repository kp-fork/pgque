---
import { Code } from '@astrojs/starlight/components';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource/saira-semi-condensed/500.css';
import '@fontsource/saira-semi-condensed/600.css';
import '@fontsource/saira-semi-condensed/700.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';

const installSql = `-- one file, any Postgres 14+, managed or self-hosted
\\i sql/pgque.sql
select pgque.start();              -- pg_cron ticks 10x/sec

select pgque.create_queue('orders');
select pgque.subscribe('orders', 'fulfilment');
select pgque.send('orders', '{"id": 42}');   -- enqueue

-- a consumer reads the current batch, then acks it
select * from pgque.receive('orders', 'fulfilment');
select pgque.ack(:batch_id);`;

const features = [
  {
    n: '01',
    title: 'Zero bloat by design',
    body: 'Snapshot-based batching and TRUNCATE-based rotation instead of per-row DELETE. No dead tuples in the hot path, immune to xmin-horizon pinning. It does not get slower because it has been running for months.',
  },
  {
    n: '02',
    title: 'The anti-extension',
    body: 'Pure SQL and PL/pgSQL. No C extension, no shared_preload_libraries, no daemon, no restart. Installs with \\i pgque.sql on RDS, Aurora, Cloud SQL, AlloyDB, Supabase, Neon, and Crunchy Bridge.',
  },
  {
    n: '03',
    title: 'Native fan-out',
    body: 'Every consumer keeps its own cursor on one shared event log and independently receives all events. No data duplication, atomic batch boundaries, late subscribers catch up. Closer to Kafka topics than to a job queue.',
  },
  {
    n: '04',
    title: 'Real Postgres guarantees',
    body: 'ACID transactions, transactional enqueue and consume, WAL, backups, replication, SQL visibility. Wrap receive + business writes + ack in one transaction for exactly-once — a property external brokers cannot offer.',
  },
  {
    n: '05',
    title: 'Built for sustained load',
    body: 'The same engine PgQ ran at Skype for messaging across hundreds of millions of users, for over a decade. PgQue rebuilds it for the heavy-load regime it was designed for.',
  },
  {
    n: '06',
    title: 'Retry, backoff, and DLQ',
    body: 'Built-in retry with configurable backoff and a dead letter queue. nack with a delay to reschedule; messages route to the DLQ after max_retries. Inspect and replay from SQL.',
  },
];

const comparison = {
  /* Columns: PgQue, PgQ, PGMQ, River, Que, pg-boss (matches the README table). */
  rows: [
    ['Snapshot batching (no row locks)', true, true, false, false, false, false],
    ['Zero bloat under sustained load', true, true, false, false, false, false],
    ['No external daemon or worker binary', true, false, true, false, false, false],
    ['Pure SQL, managed-Postgres ready', true, false, true, true, true, true],
    ['Multiple independent consumers (fan-out)', true, true, false, false, false, 'partial'],
    ['Built-in dead letter queue', true, false, 'partial', 'partial', false, true],
  ],
  cols: ['PgQue', 'PgQ', 'PGMQ', 'River', 'Que', 'pg-boss'],
};

/*
 * Language brand marks, inlined (no external/CDN requests), used nominatively.
 * Official simple-icons (CC0-1.0) single-path glyphs, verified against the
 * package SVGs (TypeScript, Python, Go). The three brand marks have
 * incompatible silhouettes in full colour — a filled blue square, organic
 * two-tone snakes, and a wide cyan "GO" wordmark — so they are unified into
 * one deliberate set: a single monochrome steel treatment, each glyph
 * normalised to the same optical cap-height on an identical tile. Monochrome
 * removes the saturated-cyan-Go imbalance and reads as one designed system.
 */
const clients = [
