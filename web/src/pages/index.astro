        transition: border-color 0.18s ease, color 0.18s ease, transform 0.1s ease;
      }
      .theme-toggle:hover { border-color: var(--accent); transform: translateY(-1px); }
      /* Icon reflects the chosen preference (auto/light/dark), not the resolved theme. */
      .theme-toggle .ic-moon,
      .theme-toggle .ic-sun,
      .theme-toggle .ic-auto { display: none; }
